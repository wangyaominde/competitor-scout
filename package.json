{
  "name": "competitor-scout",
  "version": "1.0.0",
  "description": "Competitor Scout · 竞品情报 — LLM research scan + BM25/RAG threat + param compare + beat roadmap",
  "main": "electron/main.js",
  "author": "wangyaominde",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/wangyaominde/competitor-scout.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test:secrets": "node scripts/check-secrets.js",
    "test:smoke": "node scripts/smoke-test.js",
    "test:system": "node scripts/system-test.js",
    "test:e2e": "node scripts/e2e-runtime.js",
    "test": "node scripts/check-secrets.js && node scripts/smoke-test.js && node scripts/system-test.js",
    "pack": "electron-builder --dir --publish never",
    "dist": "electron-builder --publish never",
    "dist:mac": "electron-builder --mac dmg --x64 --arm64 --publish never",
    "dist:mac:x64": "electron-builder --mac dmg --x64 --publish never -c.dmg.title=CompetitorScout-x64",
    "dist:mac:arm64": "electron-builder --mac dmg --arm64 --publish never -c.dmg.title=CompetitorScout-arm64",
    "dist:win": "electron-builder --win nsis --x64 --publish never",
    "dist:all": "npm run dist:mac:x64 && npm run dist:mac:arm64 && npm run dist:win",
    "icon": "python3 scripts/generate-icon.py"
  },
  "dependencies": {
    "adm-zip": "^0.6.0",
    "electron-store": "^8.2.0",
    "mammoth": "^1.12.0",
    "node-cron": "^3.0.3",
    "pdf-parse": "^2.4.5",
    "three": "^0.170.0",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.wangyaominde.competitor-scout",
    "productName": "CompetitorScout",
    "executableName": "CompetitorScout",
    "copyright": "Copyright © 2026 wangyaominde",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "package.json",
      "!**/.data/**",
      "!**/*.map",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,README,readme}",
      "!**/node_modules/.bin/**"
    ],
    "asar": true,
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.business",
      "icon": "build/icon.icns",
      "executableName": "CompetitorScout",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "extendInfo": {
        "CFBundleDisplayName": "CompetitorScout",
        "CFBundleName": "CompetitorScout"
      }
    },
    "win": {
      "icon": "build/icon.ico",
      "executableName": "CompetitorScout",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "CompetitorScout",
      "uninstallDisplayName": "CompetitorScout"
    },
    "dmg": {
      "title": "CompetitorScout",
      "writeUpdateInfo": false
    },
    "publish": null
  }
}
