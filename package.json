{
  "name": "competitor-intel",
  "version": "1.0.0",
  "description": "竞品情报收集与威胁分析 — LLM 联网搜索 + Agent 确认 + 多维向量匹配 + 定时扫描",
  "main": "electron/main.js",
  "author": "wangyaominde",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/wangyaominde/competitor-intel.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test:secrets": "node scripts/check-secrets.js",
    "test:smoke": "node scripts/smoke-test.js",
    "test:system": "node scripts/system-test.js",
    "test:e2e": "node scripts/e2e-runtime.js",
    "test": "node scripts/check-secrets.js && node scripts/smoke-test.js && node scripts/system-test.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "adm-zip": "^0.6.0",
    "electron-store": "^8.2.0",
    "mammoth": "^1.12.0",
    "node-cron": "^3.0.3",
    "pdf-parse": "^2.4.5",
    "three": "^0.170.0",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.wangyaominde.competitor-intel",
    "productName": "Competitor Intel",
    "copyright": "Copyright © 2026 wangyaominde",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "package.json",
      "!**/.data/**",
      "!**/*.map",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,README,readme}",
      "!**/node_modules/.bin/**"
    ],
    "asar": true,
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": null
  }
}
